generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  username           String               @unique
  password           String
  firstName          String?
  lastName           String?
  preferredLanguage  String               @default("en")
  isPremium          Boolean              @default(false)
  emailVerified         Boolean           @default(false)
  verificationCode      String?
  verificationExpiresAt DateTime?
  verificationAttempts  Int               @default(0)
  resetCode             String?
  resetExpiresAt        DateTime?
  resetAttempts         Int               @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  enrollments        CourseEnrollment[]
  lessons            LessonProgress[]
  goals              LearningGoal[]
  vocabularyProgress VocabularyProgress[]
  sessions           LearningSession[]
  interactions       LearningInteraction[]
  speechSessions     SpeechSession[]
  certificates       Certificate[]
  quizAttempts       QuizAttempt[]
  achievements       Achievement[]
  createdCourses     Course[]             @relation("CourseInstructor")
  learningPaths      LearningPath[]
  pathEnrollments    PathEnrollment[]
}

model Course {
  id                String             @id @default(uuid())
  title             String             @unique
  description       String
  level             String
  category          String             @default("LANGUAGE")
  estimatedDuration Int
  price             Float              @default(0)
  status            String             @default("PUBLISHED")
  imageUrl          String?
  tags              String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  instructorId      String?
  instructor        User?              @relation("CourseInstructor", fields: [instructorId], references: [id])
  lessons           Lesson[]
  enrollments       CourseEnrollment[]
  certificates      Certificate[]
  pathSteps         PathStep[]
}

model Lesson {
  id          String           @id @default(uuid())
  courseId    String
  title       String
  description String
  order       Int
  duration    Int
  type        String           @default("VIDEO")
  content     Json?
  status      String           @default("PUBLISHED")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  course      Course           @relation(fields: [courseId], references: [id])
  progress    LessonProgress[]
  quizzes     Quiz[]
}

model CourseEnrollment {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  isCompleted Boolean  @default(false)
  progress    Float    @default(0)
  enrolledAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model LessonProgress {
  id                   String   @id @default(uuid())
  userId               String
  lessonId             String
  status               String   @default("NOT_STARTED")
  completionPercentage Float    @default(0)
  timeSpentMinutes     Int      @default(0)
  attempts             Int      @default(0)
  lastAccessedAt       DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
  lesson               Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model LearningPath {
  id                String           @id @default(uuid())
  title             String
  description       String?          @db.Text
  difficulty        String           @default("BEGINNER")
  creatorId         String
  status            String           @default("DRAFT")
  tags              String           @default("[]")
  prerequisites     String           @default("[]")
  estimatedDuration Int?             @default(0)
  publishedAt       DateTime?
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  creator           User             @relation(fields: [creatorId], references: [id])
  steps             PathStep[]
  enrollments       PathEnrollment[]
}

model PathStep {
  id            String       @id @default(uuid())
  pathId        String
  courseId      String?
  title         String
  description   String?      @db.Text
  order         Int
  isRequired    Boolean      @default(true)
  estimatedTime Int?         @default(0)
  metadata      Json?
  learningPath  LearningPath @relation(fields: [pathId], references: [id])
  course        Course?      @relation(fields: [courseId], references: [id])
}

model PathEnrollment {
  id            String       @id @default(uuid())
  userId        String
  pathId        String
  progress      Int          @default(0)
  status        String       @default("ACTIVE") // ACTIVE, COMPLETED
  enrolledAt    DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id])
  learningPath  LearningPath @relation(fields: [pathId], references: [id])

  @@unique([userId, pathId])
}

model LearningGoal {
  id        String   @id @default(uuid())
  userId    String
  goals     String   @default("[]") // JSON string of goals
  timeframe String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model DictionaryLookup {
  id            String   @id @default(uuid())
  word          String
  language      String   @default("en")
  definition    String?
  pronunciation String?
  partOfSpeech  String?
  examples      String?  @db.Text // JSON string
  synonyms      String?  @db.Text // JSON string
  antonyms      String?  @db.Text // JSON string
  etymology     String?  @db.Text
  frequency     Float?
  difficulty    Int?
  source        String?  @default("free_dictionary")
  accessedCount Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([word, language])
}

model VocabularyItem {
  id            String               @id @default(uuid())
  word          String
  language      String
  definition    String?
  partOfSpeech  String?
  difficulty    Int?                 @default(1)
  tags          String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  userProgress  VocabularyProgress[]
}

model VocabularyProgress {
  id               String         @id @default(uuid())
  userId           String
  vocabularyItemId String
  status           String         @default("NEW") // NEW, LEARNING, MASTERED
  masteryLevel     Int            @default(0) // 0-100
  lastEncountered  DateTime?
  nextReviewAt     DateTime?
  correctCount     Int            @default(0)
  incorrectCount   Int            @default(0)
  streak           Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id])
  vocabularyItem   VocabularyItem @relation(fields: [vocabularyItemId], references: [id])

  @@unique([userId, vocabularyItemId])
}

model RolePlayScenario {
  id           String            @id @default(uuid())
  title        String
  description  String
  category     String
  difficulty   Int               @default(1)
  instructions String?           @db.Text
  isLocked     Boolean           @default(false)
  isPremium    Boolean           @default(false)
  tags         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sessions     LearningSession[]
}

model TechnologyTopic {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String   // AI_BASICS, PROGRAMMING, DRONES, BIOMEDICAL, IOT, etc.
  difficulty  Int      @default(1)
  tags        String   @default("[]") // JSON string
  isLocked    Boolean  @default(false)
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LearningSession {
  id          String                @id @default(uuid())
  userId      String
  scenarioId  String?
  type        String                @default("CONVERSATION") // CONVERSATION, ROLEPLAY, TUTOR
  language    String                @default("en")
  status      String                @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  feedback    String?               @db.Text
  score       Int?
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  user        User                  @relation(fields: [userId], references: [id])
  scenario    RolePlayScenario?     @relation(fields: [scenarioId], references: [id])
  interactions LearningInteraction[]
}

model LearningInteraction {
  id              String          @id @default(uuid())
  sessionId       String
  userId          String
  role            String          // USER, ASSISTANT
  content         String          @db.Text
  audioUrl        String?
  grammarErrors   Json?           // Structured grammar analysis
  nativeVersion   String?         @db.Text
  createdAt       DateTime        @default(now())
  session         LearningSession @relation(fields: [sessionId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
}

model SpeechSession {
  id               String    @id @default(uuid())
  userId           String
  targetLanguage   String
  audioUrl         String
  transcription    String?   @db.Text
  translation      String?   @db.Text
  confidence       Float?
  duration         Int?      @default(0)
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])
  assessment       SpeechAssessment?
}

model SpeechAssessment {
  id                 String        @id @default(uuid())
  speechSessionId    String        @unique
  overallScore       Float
  pronunciationScore Float
  fluencyScore       Float
  clarityScore       Float
  wordScores         Json?         // Detailed word-level scores
  feedback           String?       @db.Text
  improvementAreas   String?       @db.Text // JSON string
  strongPoints       String?       @db.Text // JSON string
  createdAt          DateTime      @default(now())
  speechSession      SpeechSession @relation(fields: [speechSessionId], references: [id])
}

model Certificate {
  id               String    @id @default(uuid())
  userId           String
  courseId         String?
  title            String
  description      String?   @db.Text
  type             String    // COMPLETION, SKILL_ASSESSMENT, etc.
  status           String    @default("ACTIVE") // ACTIVE, REVOKED
  issuerName       String    @default("VibeOn")
  issueDate        DateTime  @default(now())
  verifyCode       String    @unique
  metadata         Json?     // criteria, achievements, scores
  user             User      @relation(fields: [userId], references: [id])
  course           Course?   @relation(fields: [courseId], references: [id])
}

model Quiz {
  id          String        @id @default(uuid())
  lessonId    String
  title       String
  description String?
  passingScore Int          @default(70)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lesson      Lesson        @relation(fields: [lessonId], references: [id])
  questions   Question[]
  attempts    QuizAttempt[]
}

model Achievement {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String?
  type            String   // COURSE_COMPLETION, STREAK, QUIZ_MASTER, etc.
  xpReward        Int      @default(0)
  unlockedAt      DateTime @default(now())
  metadata        Json?
  user            User     @relation(fields: [userId], references: [id])
}

model Question {
  id             String   @id @default(uuid())
  quizId         String
  text           String
  type           String   @default("MULTIPLE_CHOICE")
  options        Json?    // Array of options
  correctAnswer  String
  explanation    String?
  points         Int      @default(1)
  quiz           Quiz     @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id          String    @id @default(uuid())
  userId      String
  quizId      String
  score       Int
  status      String    @default("COMPLETED")
  answers     Json?     // Array of user answers
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id])
  quiz        Quiz      @relation(fields: [quizId], references: [id])
}
